# ─────────────────────────────────────────────────────────────────────────────
# ENOCOMATIK — Variables de Entorno Requeridas
# ─────────────────────────────────────────────────────────────────────────────
# Copiar este archivo como .env y rellenar con valores reales.
# NUNCA subir el .env a control de versiones (.gitignore ya lo excluye).
# ─────────────────────────────────────────────────────────────────────────────

# ──────── SERVIDOR ────────
NODE_ENV=production
PORT=4000

# ──────── POSTGRESQL (AWS RDS o Neon.tech en staging) ────────
DATABASE_URL=postgresql://usuario:contraseña@host:5432/enocomatik_db

# ──────── MONGODB ATLAS (CMDB + Kardex) ────────
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/enocomatik_cmdb

# ──────── REDIS (Upstash en staging, AWS ElastiCache en producción) ────────
REDIS_URL=redis://localhost:6379

# ──────── JWT ASIMÉTRICO ────────
# Generar con: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_EXPIRES_IN=8h

# ──────── CIFRADO AES-256 [REQUERIDO — FAIL-FAST SI NO SE DEFINE] ────────
# Generar con: openssl rand -hex 32
# NUNCA usar los vectores de prueba FIPS-197 de NIST (603deb... / 2b7e15...)
AES_KEY=REEMPLAZAR_CON_CLAVE_HEX_DE_64_CARACTERES

# ──────── USUARIOS SEMILLA (opcionales — si no se definen, se generan aleatoriamente) ────────
# Si se generan aleatoriamente, las contraseñas se imprimirán UNA VEZ en el log del servidor.
SEED_ADMIN_PASSWORD=REEMPLAZAR_CON_CONTRASENA_SEGURA
SEED_TECNICO_PASSWORD=REEMPLAZAR_CON_CONTRASENA_SEGURA

# ──────── RENDER (despliegue backend) ────────
# Obtener desde: Render Dashboard → tu servicio → Settings → Deploy Hook
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-XXXXXXX?key=XXXXXXXX

# ──────── VERCEL (despliegue frontend) ────────
VERCEL_TOKEN=REEMPLAZAR_CON_TOKEN_DE_VERCEL
VERCEL_ORG_ID=REEMPLAZAR_CON_ORG_ID
VERCEL_PROJECT_ID=REEMPLAZAR_CON_PROJECT_ID

# ──────── NETLIFY (previews de Pull Requests) ────────
NETLIFY_AUTH_TOKEN=REEMPLAZAR_CON_TOKEN_DE_NETLIFY
NETLIFY_SITE_ID=REEMPLAZAR_CON_SITE_ID
